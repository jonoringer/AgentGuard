# Core
AGENTGUARD_SERVICE_NAME=agentguard-prod
AGENTGUARD_POLICY=/etc/agentguard/policy.json

# Stores (Postgres recommended)
AGENTGUARD_AUDIT_DB=postgresql://user:pass@db:5432/agentguard
AGENTGUARD_POLICY_DB=postgresql://user:pass@db:5432/agentguard
AGENTGUARD_SCIM_DB=postgresql://user:pass@db:5432/agentguard

# Auth (pick one or combine)
AGENTGUARD_API_KEYS=viewer-key:viewer,operator-key:operator,admin-key:admin
AGENTGUARD_OIDC_ISSUER=https://issuer.example.com
AGENTGUARD_OIDC_AUDIENCE=agentguard-api
AGENTGUARD_OIDC_JWKS_URL=https://issuer.example.com/.well-known/jwks.json
AGENTGUARD_OIDC_ROLE_CLAIM=role
AGENTGUARD_OIDC_TENANT_CLAIM=tenant_id

# Trusted SSO bridge
AGENTGUARD_TRUSTED_SSO_SHARED_SECRET=change-me
AGENTGUARD_TRUSTED_SSO_USER_HEADER=x-agentguard-user
AGENTGUARD_TRUSTED_SSO_ROLE_HEADER=x-agentguard-role
AGENTGUARD_TRUSTED_SSO_TENANT_HEADER=x-agentguard-tenant
AGENTGUARD_TRUSTED_SSO_SECRET_HEADER=x-agentguard-sso-secret

# Telemetry
AGENTGUARD_ENABLE_OTEL=true
AGENTGUARD_OTEL_ENDPOINT=http://otel-collector:4318
AGENTGUARD_TELEMETRY_JSONL_PATH=/var/log/agentguard/telemetry.jsonl

# SIEM
AGENTGUARD_SIEM_JSONL_PATH=/var/log/agentguard/siem.jsonl
AGENTGUARD_SIEM_WEBHOOK_URL=https://siem.example.com/ingest
AGENTGUARD_SIEM_SYSLOG_HOST=10.0.0.25
AGENTGUARD_SIEM_SYSLOG_PORT=514

# DLP providers (optional)
AGENTGUARD_DLP_AWS_REGION=us-east-1
AGENTGUARD_DLP_GCP_PROJECT=my-gcp-project
AGENTGUARD_DLP_PRESIDIO=true
AGENTGUARD_DLP_HTTP_ENDPOINT=https://dlp.example.com/inspect
AGENTGUARD_DLP_HTTP_API_KEY=dlp-token
